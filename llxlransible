#!/bin/bash

set -e

REPO="https://github.com/mijuanlo/llxlransible"
WORKDIR="/root/.ansible-repo"
PLAYBOOK="local.yml"

# Variables de entorno
export PYTHONDONTWRITEBYTECODE=1

# Clonar o actualizar
if [ -d "$WORKDIR/.git" ]; then
    echo "Actualizando repositorio..."
    cd "$WORKDIR"
    # Descargar la última información del repositorio principal (sin aplicarla aún)
    git fetch origin
    # Forzar el repositorio principal para que sea idéntico a la rama remota
    git reset --hard "origin/master"
    # Limpiar cualquier archivo o carpeta no rastreada en el repo principal
    git clean -fd
    # Actualizar los submódulos a los punteros exactos dictados por el repo principal,
    # forzando el descarte de cualquier cambio local dentro de ellos
    git submodule update --init --recursive --force
    # Limpiar cualquier archivo no rastreado que haya quedado dentro de los submódulos
    git submodule foreach --recursive git clean -fd
else
    echo "Clonando repositorio..."
    rm -rf "$WORKDIR"
    git clone --recursive "$REPO" "$WORKDIR"
    cd "$WORKDIR"
fi

# Ejecutar con ansible-playbook (utilizando ansible.cfg local)
ansible-playbook \
    -i localhost, \
    --connection=local \
    "$PLAYBOOK"